{
  "name": "subnet-client",
  "version": "0.31.0",
  "description": "SDK for joining and interacting with subnets — EIP-191 accountability signing and Matrix communication",
  "main": "index.js",
  "exports": {
    ".": {
      "browser": "./index.js",
      "node": "./index.js",
      "default": "./index.js"
    }
  },
  "imports": {
    "#matrix-impl": {
      "browser": "./lib/matrix_e2e_browser.js",
      "node": "./lib/matrix_e2e.js",
      "default": "./lib/matrix_e2e.js"
    },
    "#node-only": {
      "browser": "./lib/node_only_stub.js",
      "node": "./lib/node_only.js",
      "default": "./lib/node_only.js"
    }
  },
  "bin": {
    "subnet": "./cli.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "subnet",
    "ethereum",
    "eip-191",
    "matrix",
    "accountability",
    "agent",
    "ai-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "ethers": "^6.0.0",
    "marked": "^18.0.0",
    "matrix-js-sdk": "^36.0.0"
  },
  "optionalDependencies": {
    "@matrix-org/matrix-sdk-crypto-nodejs": "^0.4.0",
    "better-sqlite3": "^12.8.0"
  }
}
